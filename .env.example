# MONGODB_URI: Connection string for MongoDB Atlas.
# Format: mongodb+srv://<username>:<password>@cluster0.mongodb.net/farmApp
MONGODB_URI=

# PORT: The port the backend server will listen on.
# Defaults to 3000 if not set.
PORT=3000

# JWT_SECRET: Secret key for signing JWT tokens.
JWT_SECRET=

# VITE_API_URL: The URL of your deployed backend API.
# Required for production deployment.
VITE_API_URL=https://backend-5oi6.onrender.com

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=
